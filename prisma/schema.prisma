generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  avatar           String?
  password         String?
  createdAt        DateTime  @default(now())
  nativeLanguage   String    @default("English")
  targetLanguage   String    @default("Spanish")
  currentLevel     String    @default("A1")
  xpTotal          Int       @default(0)
  streakCurrent    Int       @default(0)
  streakLongest    Int       @default(0)
  lastActivityAt    DateTime?
  dailyGoalMinutes  Int       @default(10)
  streakFrozenUntil DateTime?

  settings           UserSettings?
  lessonProgress     UserLessonProgress[]
  flashcards         UserFlashcard[]
  achievements       UserAchievement[]
  conversations      AIConversation[]
  writingEntries     WritingEntry[]
  dailyChallenges    UserDailyChallenge[]
  leaderboardEntries Leaderboard[]
  accounts           Account[]
  sessions           Session[]
  friendships        Friendship[]        @relation("UserFriends")
  friendOf           Friendship[]        @relation("FriendUsers")
  pushSubscriptions  PushSubscription[]
  goalCycles         GoalCycle[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  id                   String  @id @default(cuid())
  userId               String  @unique
  notificationsEnabled Boolean @default(true)
  reminderTime         String  @default("20:00")
  theme                String  @default("light")
  uiLanguage           String  @default("English")
  streakFreezeCount    Int     @default(1)
  inviteCode           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  user      User     @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend    User     @relation("FriendUsers", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}

model Lesson {
  id               String @id @default(cuid())
  title            String
  description      String
  level            String
  unit             Int
  order            Int
  type             String
  estimatedMinutes Int    @default(10)
  xpReward         Int    @default(30)
  content          String

  flashcards   Flashcard[]
  userProgress UserLessonProgress[]
  goalLessons  GoalLesson[]
}

model UserLessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  status      String    @default("NOT_STARTED")
  score       Int       @default(0)
  completedAt DateTime?
  attempts    Int       @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Flashcard {
  id       String  @id @default(cuid())
  front    String
  back     String
  audioUrl String?
  imageUrl String?
  lessonId String
  language String
  tags     String  @default("")

  lesson         Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  userFlashcards UserFlashcard[]
}

model UserFlashcard {
  id            String    @id @default(cuid())
  userId        String
  flashcardId   String
  interval      Int       @default(1)
  easeFactor    Float     @default(2.5)
  dueDate       DateTime  @default(now())
  repetitions   Int       @default(0)
  lastReviewed  DateTime?
  correctStreak Int       @default(0)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
}

model Achievement {
  id          String @id @default(cuid())
  title       String
  description String
  icon        String
  xpReward    Int
  condition   String

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  language  String
  scenario  String
  messages  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WritingEntry {
  id         String   @id @default(cuid())
  userId     String
  content    String
  language   String
  aiFeedback String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyChallenge {
  id       String   @id @default(cuid())
  date     DateTime @unique
  type     String
  content  String
  xpReward Int      @default(60)

  userChallenges UserDailyChallenge[]
}

model UserDailyChallenge {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  completedAt DateTime @default(now())
  score       Int      @default(0)

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge DailyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Leaderboard {
  id        String   @id @default(cuid())
  userId    String
  weekStart DateTime
  xpEarned  Int      @default(0)
  rank      Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
}

model GoalCycle {
  id              String    @id @default(cuid())
  userId          String
  title           String
  description     String
  topic           String
  cefrLevel       String
  skillFocus      String
  status          String    @default("SUGGESTED")
  durationDays    Int
  startedAt       DateTime?
  deadlineAt      DateTime?
  completedAt     DateTime?
  xpMultiplier    Float     @default(1.5)
  xpBonusEarned   Int       @default(0)
  passThreshold   Int       @default(70)
  sequenceNumber  Int       @default(0)
  aiContext       String
  createdAt       DateTime  @default(now())

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyPlans       GoalDailyPlan[]
  assignedLessons  GoalLesson[]
  masteryTests     GoalMasteryTest[]

  @@index([userId, status])
}

model GoalLesson {
  id          String    @id @default(cuid())
  goalId      String
  lessonId    String
  dayNumber   Int
  isRequired  Boolean   @default(true)
  completedAt DateTime?

  goal   GoalCycle @relation(fields: [goalId], references: [id], onDelete: Cascade)
  lesson Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([goalId, lessonId])
}

model GoalDailyPlan {
  id            String   @id @default(cuid())
  goalId        String
  dayNumber     Int
  date          DateTime
  lessonIds     String
  rationale     String
  isCompleted   Boolean  @default(false)
  createdAt     DateTime @default(now())

  goal GoalCycle @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, dayNumber])
}

model GoalMasteryTest {
  id              String    @id @default(cuid())
  goalId          String
  attempt         Int       @default(1)
  testCategories  String
  questions       String
  answers         String?
  score           Int?
  passed          Boolean?
  remedialPlan    String?
  takenAt         DateTime?
  createdAt       DateTime  @default(now())

  goal GoalCycle @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}
